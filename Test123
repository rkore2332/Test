The easiest and most reliable way is to use the OneDrive-synced local path, not the browser URL.

import win32com.client
import os
import time

excel_file = r"C:\Users\rajesh.kore\OneDrive - Company & Co, Inc\CRE Reporting\PowerQuery_Join_Test_Workbook.xlsx"

if not os.path.exists(excel_file):
    raise FileNotFoundError(f"File not found: {excel_file}")

excel = win32com.client.Dispatch("Excel.Application")
excel.Visible = True
excel.DisplayAlerts = True

try:
    print("Opening SharePoint synced Excel file...")
    wb = excel.Workbooks.Open(excel_file)

    print("Refreshing Power Query...")
    wb.RefreshAll()

    time.sleep(30)

    print("Saving workbook back to SharePoint synced folder...")
    wb.Save()

    wb.Close()
    print("SharePoint file refreshed successfully.")

except Exception as e:
    print("Error:", e)

finally:
    excel.Quit()




#############
This works if:

Excel desktop is installed
OneDrive sync is enabled
You have edit access
The file is not open by another user
The file is fully synced locally


#######

Recommended production flow
SharePoint Excel file
      ↓
OneDrive sync local path
      ↓
Python opens workbook
      ↓
Refresh Power Query
      ↓
Save workbook
      ↓
OneDrive sync uploads changes back to SharePoint

