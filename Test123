import win32com.client
import os
import time
import traceback
from datetime import datetime

# =========================
# CONFIGURATION
# =========================

excel_file = r"C:\Users\rajesh.kore\OneDrive - company & Co, Inc\Desktop\Power Query Refresh Automation\PowerQuery_Join_Test_Workbook.xlsx"

email_to = "recipient@company.com"
email_cc = ""

# =========================
# EMAIL FUNCTION
# =========================

def send_outlook_email(subject, body):
    outlook = win32com.client.Dispatch("Outlook.Application")
    mail = outlook.CreateItem(0)
    mail.To = email_to
    mail.CC = email_cc
    mail.Subject = subject
    mail.Body = body
    mail.Send()

# =========================
# MAIN PROCESS
# =========================

excel = None
wb = None
start_time = datetime.now()

try:
    if not os.path.exists(excel_file):
        raise FileNotFoundError(f"File not found: {excel_file}")

    excel = win32com.client.Dispatch("Excel.Application")
    excel.Visible = True
    excel.DisplayAlerts = True

    print("Opening workbook...")
    wb = excel.Workbooks.Open(excel_file)

    print("Refreshing Power Query...")
    wb.RefreshAll()

    excel.CalculateUntilAsyncQueriesDone()
    time.sleep(10)

    print("Saving refreshed workbook...")
    wb.Save()
    wb.Close()
    wb = None

    end_time = datetime.now()
    duration = end_time - start_time

    send_outlook_email(
        "SUCCESS: Power Query Workbook Refresh Completed",
        f"""
Power Query workbook refresh completed successfully.

File:
{excel_file}

Start Time:
{start_time}

End Time:
{end_time}

Duration:
{duration}

Status:
SUCCESS
"""
    )

    print("Refresh completed successfully.")

except Exception as e:
    end_time = datetime.now()
    duration = end_time - start_time
    error_details = traceback.format_exc()

    send_outlook_email(
        "FAILED: Power Query Workbook Refresh Failed",
        f"""
Power Query workbook refresh failed.

File:
{excel_file}

Start Time:
{start_time}

End Time:
{end_time}

Duration:
{duration}

Status:
FAILED

Error:
{str(e)}

Details:
{error_details}
"""
    )

    print("Refresh failed:", e)

finally:
    try:
        if wb is not None:
            wb.Close(SaveChanges=False)
    except:
        pass

    try:
        if excel is not None:
            excel.Quit()
    except:
        pass


